# Copy to .env and fill in — .env is gitignored.
# All values read by deepsecurity/config.py (pydantic-settings).

# --- Core -----------------------------------------------------------------
# Environment: development | staging | production
DEEPSEC_ENV=development

# Flask / API
DEEPSEC_SECRET_KEY=change-me-to-a-32-char-random-string
DEEPSEC_JWT_SECRET=change-me-to-another-32-char-random-string
DEEPSEC_JWT_ACCESS_MINUTES=60

# Bind address
DEEPSEC_HOST=127.0.0.1
DEEPSEC_PORT=5000

# CORS: comma-separated list of allowed origins. Never use "*" in production.
DEEPSEC_CORS_ORIGINS=http://localhost:5173

# --- Database -------------------------------------------------------------
# SQLite (default — personal / single-node):
DEEPSEC_DATABASE_URL=sqlite:///data/deepscan.db
#
# PostgreSQL (recommended for multi-user, concurrent writes, or production).
# Install the driver first:  pip install "deepsecurity[postgres]"
# Then point at your cluster, e.g.
#     DEEPSEC_DATABASE_URL=postgresql+psycopg://deepsec:pass@localhost:5432/deepsec
# docker-compose.yml already includes a ready-to-use postgres service —
# see docs/POSTGRES.md for the step-by-step.
#
# If you use docker-compose, set this too:
# POSTGRES_PASSWORD=

# --- Scanner --------------------------------------------------------------
# DEEPSEC_SCAN_ROOT is OPTIONAL.
#
# Leave blank (the default) for local / personal use — you'll be able to
# scan any absolute path: a drive, a folder, or a single file. OS-agnostic.
#
# Set it only if you want to lock the scanner down to specific paths —
# useful when you're deploying this as a shared service and the caller
# should not be trusted to pick the target.
#
# Accepts a single path or a semicolon- / comma-separated list:
#     DEEPSEC_SCAN_ROOT=
#     DEEPSEC_SCAN_ROOT=C:\Apps
#     DEEPSEC_SCAN_ROOT=C:\Apps\DEEPSecurity_v2.0\samples;C:\Apps\Imgs2
#     DEEPSEC_SCAN_ROOT=/home/dino/Downloads,/mnt/external
DEEPSEC_SCAN_ROOT=

# Where quarantined files are copied (NEVER deleted unless the operator acts).
DEEPSEC_QUARANTINE_DIR=./quarantine
DEEPSEC_SAFELIST_DIR=./safelist
DEEPSEC_DELETED_DIR=./deleted

# Signature file: one SHA256 hex digest per line
DEEPSEC_SIGNATURE_PATH=./data/signatures.txt

# ML model on disk (joblib). Leave unset to disable the ML layer entirely
# (the scanner will run with signature + entropy only and log honestly about it).
DEEPSEC_ML_MODEL_PATH=

# Minimum ML confidence required for a detection to count. 0.0–1.0.
DEEPSEC_ML_CONFIDENCE_THRESHOLD=0.85

# --- Outlook (Windows only) ----------------------------------------------
# When true, Outlook attachment scanning is available via the API.
DEEPSEC_OUTLOOK_ENABLED=false
# Never delete. Always quarantine. This is a default — keep it this way.
DEEPSEC_OUTLOOK_DELETE_ON_DETECT=false

# --- Logging --------------------------------------------------------------
DEEPSEC_LOG_LEVEL=INFO
DEEPSEC_LOG_JSON=true

# --- YARA -----------------------------------------------------------------
# Directory of .yar / .yara rule files. Leave unset to disable.
DEEPSEC_YARA_RULES_DIR=

# --- Realtime watchdog customisation -------------------------------------
# Override the built-in "user_risk" scope with your own paths
# (semicolon- or comma-separated). Leave blank for the default
# (Downloads, Desktop, Documents, Outlook cache, %TEMP%).
DEEPSEC_USER_RISK_PATHS=
# Glob patterns that are NEVER scanned regardless of the watched path.
# The default catches the usual noise: node_modules, Python venvs, IDE
# caches, Chrome/browser caches, Thumbs.db, .DS_Store, etc. Extend or
# replace if you have a specific noise source that's burning CPU.
DEEPSEC_WATCH_EXCLUDE_GLOBS=**/node_modules/**;**/.venv/**;**/venv/**;**/.git/**;**/__pycache__/**;**/.pytest_cache/**;**/.mypy_cache/**;**/.ruff_cache/**;**/htmlcov/**;**/.idea/**;**/.vscode/**;**/Code Cache/**;**/GPUCache/**;**/Cache_Data/**;**/Media Cache/**;**/Service Worker/**;**/*.pyc;**/*.pyo;**/Thumbs.db;**/.DS_Store;**/desktop.ini

# --- DLP ------------------------------------------------------------------
DEEPSEC_DLP_ENABLED=true
# Files larger than this are not scanned for secrets (2 MiB default).
DEEPSEC_DLP_MAX_BYTES=2097152

# --- Threat intel feeds --------------------------------------------------
DEEPSEC_INTEL_MALWAREBAZAAR_ENABLED=false

# --- Alert sinks ---------------------------------------------------------
# Slack / generic webhook — fire on detection.malicious + dlp.critical.
DEEPSEC_SLACK_WEBHOOK_URL=
DEEPSEC_ALERT_WEBHOOK_URL=

# RFC-5424 UDP syslog (plain JSON in the message body).
DEEPSEC_SYSLOG_HOST=
DEEPSEC_SYSLOG_PORT=514

# SIEM-ready CEF-over-syslog. Splunk / Elastic / Sentinel / ArcSight /
# QRadar / Exabeam / LogRhythm all auto-parse CEF into typed fields — no
# custom grok / dissect needed. Leave CEF_HOST blank to disable. Use
# CEF_PROTOCOL=tcp if your collector doesn't accept UDP.
DEEPSEC_CEF_HOST=
DEEPSEC_CEF_PORT=514
DEEPSEC_CEF_PROTOCOL=udp

# Email (STARTTLS). Leave host blank to disable.
DEEPSEC_SMTP_HOST=
DEEPSEC_SMTP_PORT=587
DEEPSEC_SMTP_USERNAME=
DEEPSEC_SMTP_PASSWORD=
DEEPSEC_SMTP_STARTTLS=true
DEEPSEC_ALERT_EMAIL_FROM=
DEEPSEC_ALERT_EMAIL_TO=

# --- Rate limit + request caps -------------------------------------------
DEEPSEC_RATE_LIMIT_ANON_PER_MINUTE=30
DEEPSEC_RATE_LIMIT_AUTH_PER_MINUTE=120
DEEPSEC_MAX_REQUEST_BYTES=10485760

# --- Retention -----------------------------------------------------------
# Used by `deepsec purge` and /api/compliance/purge.
DEEPSEC_RETENTION_DAYS=90

# --- Dev bootstrap user --------------------------------------------------
# Swap for a real IdP before exposing beyond localhost.
DEEPSEC_DEV_USER=admin
DEEPSEC_DEV_PASSWORD=
DEEPSEC_DEV_ROLE=admin
